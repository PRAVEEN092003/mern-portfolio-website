# ─── Environment ───────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ─── Database ──────────────────────────────────────────────────
# Paste your MongoDB Atlas connection string here
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/portfolio?retryWrites=true&w=majority

# ─── Security ──────────────────────────────────────────────────
# Random secret used to protect admin API routes
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_API_KEY=your_super_secret_admin_key_here

# ─── CORS ──────────────────────────────────────────────────────
# Local dev: http://localhost:5173  |  Production: your Vercel URL
FRONTEND_URL=http://localhost:5173
